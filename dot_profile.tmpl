# Start the SSH agent if it's not running
if [ -z "$SSH_AUTH_SOCK" ]; then
  eval "$(ssh-agent -s -q)" >/dev/null
fi

# Core environment variables
export EDITOR=vim
export VISUAL=vim
export PAGER=bat
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export BROWSER=open
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export LESS='-R -F -X'

# goenv
export GOENV_ROOT="$HOME/.goenv"
export PATH="$GOENV_ROOT/bin:$PATH"
export PATH="$GOROOT/bin:$PATH"
export PATH="$PATH:$GOPATH/bin"

if command -v goenv >/dev/null 2>&1; then
  eval "$(goenv init -)" >/dev/null
fi

# volta
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"

# rustup
RUSTUP_BIN="${RUSTUP_BIN:-$(brew --prefix rustup)/bin}"
export PATH="$RUSTUP_BIN:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"

# Deduplicate PATH
typeset -U PATH

# FZF configuration
export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git --exclude node_modules'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --exclude .git --exclude node_modules'
export FZF_DEFAULT_OPTS='
  --height 40%
  --layout=reverse
  --border=rounded
  --preview="bat --style=numbers --color=always {}"
  --preview-window=right:50%
  --prompt="❯ "
  --pointer="▶"
  --marker="✓"
  --bind="ctrl-u:preview-page-up,ctrl-d:preview-page-down"
  --color=fg:#f8f8f2,bg:#282a36,hl:#ff79c6
  --color=fg+:#f8f8f2,bg+:#44475a,hl+:#ff79c6
  --color=info:#8be9fd,prompt:#50fa7b,pointer:#ffb86c
  --color=marker:#bd93f9,spinner:#ff5555,header:#6272a4'

# terminal-wakatime setup
export PATH="$HOME/.wakatime:$PATH"
eval "$(terminal-wakatime init)"
